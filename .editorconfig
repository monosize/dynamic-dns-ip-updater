# EditorConfig hilft Entwicklern, für verschiedene Editoren und IDEs einen konsistenten Codier-Stil zu definieren und beizubehalten
root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 4
indent_style = space
insert_final_newline = true
max_line_length = 120
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false

[*.{yaml,yml}]
indent_size = 2

[*.json]
indent_size = 2

[*.xml{,.dist}]
indent_size = 2

[*.{html,html.twig}]
indent_size = 2

[composer.json]
indent_size = 4