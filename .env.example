# Comma-separated list of domains to monitor
# Append :ip4, :ip6, or :both (default) to specify IP version per domain
DNS_DOMAINS=example1.mywire.org:both,example2.mywire.org:ip6

# External IPv4 service used as fallback when the domain has no A record (e.g. DS-Lite / IPv6-only connections)
# Default: https://api4.ipify.org
#EXTERNAL_IPV4_SERVICE=https://api4.ipify.org