{
  "name": "monosize/dynamic-dns-ip-updater",
  "description": "Updates .htaccess with current IP addresses from dynamic DNS domains",
  "type": "symfony-bundle",
  "license": "MIT",
  "authors": [
    {
      "name": "Monosize",
      "email": "info@monosize.de"
    }
  ],
  "require": {
    "php": ">=8.1",
    "symfony/framework-bundle": "^6.0|^7.0",
    "symfony/console": "^6.0|^7.0",
    "symfony/cache": "^6.0|^7.0",
    "symfony/dotenv": "^6.0|^7.0",
    "psr/log": "^3.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0",
    "symfony/phpunit-bridge": "^6.0|^7.0",
    "friendsofphp/php-cs-fixer": "^3.0",
    "phpstan/phpstan": "^1.0",
    "symfony/var-dumper": "^6.0|^7.0"
  },
  "suggest": {
    "ext-pcov": "Required for generating code coverage reports in tests",
    "ext-xdebug": "Can be used as an alternative for generating code coverage reports"
  },
  "autoload": {
    "psr-4": {
      "Monosize\\DynamicDnsIpUpdater\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Monosize\\DynamicDnsIpUpdater\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "test-coverage": [
      "@putenv XDEBUG_MODE=coverage",
      "phpunit --coverage-html coverage"
    ],
    "cs-check": "php-cs-fixer fix --dry-run --diff",
    "cs-fix": "php-cs-fixer fix",
    "phpstan": "phpstan analyse src tests --level=max",
    "check-all": [
      "@cs-check",
      "@phpstan",
      "@test"
    ]
  },
  "config": {
    "sort-packages": true
  },
  "extra": {
    "symfony": {
      "allow-contrib": false,
      "require": "^6.0|^7.0"
    }
  }
}